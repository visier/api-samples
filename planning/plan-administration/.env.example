# Example environment variables for plan administration script

# Visier auth variables
VISIER_HOST=https://customer-specific.ai.visier.io
VISIER_API='visier-provided-api-key'
VISIER_USERNAME='visier-username'
VISIER_PASSWORD='visier-password'
VISIER_VANITY='visier-tenant-vanity-name'

# Required: Target plan name to process
TARGET_PLAN_NAME='Untitled'


# Optional: Enable verbose logging for detailed information (default: false)
# Set to true, 1, yes, or on to enable verbose logging
# When disabled, only errors and critical information will be shown
VERBOSE=false
